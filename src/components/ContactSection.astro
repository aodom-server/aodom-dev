---
import type { ResumeContent } from "../data/resume";

interface Props {
  content: ResumeContent;
}

const { content } = Astro.props;
---

<section class="bg-ink py-16 text-white sm:py-24" id="contact">
  <div class="mx-auto w-[min(1160px,calc(100%_-_1.75rem))]">
    <div class="reveal grid gap-8 rounded-lg border border-white/10 bg-white/[0.03] p-6 shadow-2xl shadow-black/25 opacity-0 translate-y-5 transition-all duration-700 ease-out data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100 lg:grid-cols-[0.8fr_1.2fr] lg:p-8">
      <div>
        <p class="mb-3 text-sm font-black uppercase tracking-[0.08em] text-teal">{content.contact.label}</p>
        <h2 class="mb-4 text-3xl font-black leading-tight sm:text-5xl">{content.contact.title}</h2>
        <p class="max-w-xl leading-8 text-white/75">{content.contact.text}</p>
        <p class="mt-5 rounded-lg border border-white/10 bg-white/5 p-4 text-sm font-semibold leading-6 text-white/70">{content.contact.note}</p>
      </div>
      <form class="contact-form" data-contact-form>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            content.contact.fields.map((field) => (
              <label class={field.type === "textarea" ? "grid gap-2 sm:col-span-2" : "grid gap-2"}>
                <span class="text-sm font-black uppercase tracking-[0.08em] text-white/65">{field.label}</span>
                {field.type === "textarea" ? (
                  <textarea class="min-h-32 rounded-lg border border-white/15 bg-white/95 px-4 py-3 text-ink outline-none transition placeholder:text-slate-400 focus:border-teal focus:ring-4 focus:ring-teal/20" name={field.id} placeholder={field.placeholder} rows="5"></textarea>
                ) : (
                  <input class="min-h-12 rounded-lg border border-white/15 bg-white/95 px-4 text-ink outline-none transition placeholder:text-slate-400 focus:border-teal focus:ring-4 focus:ring-teal/20" name={field.id} type={field.type} placeholder={field.placeholder} />
                )}
              </label>
            ))
          }
        </div>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
          <button class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white bg-white px-5 font-black text-ink transition hover:-translate-y-0.5" type="submit">Preview message</button>
          <span class="text-sm font-semibold text-white/65" data-form-status>Preview only - no message is sent yet.</span>
        </div>
      </form>
    </div>
  </div>
</section>
