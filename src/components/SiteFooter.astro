---
import type { ResumeContent } from "../data/resume";

interface Props {
  content: ResumeContent;
}

const { content } = Astro.props;
---

<footer class="bg-paper py-8 text-sm text-muted">
  <div class="mx-auto flex w-[min(1160px,calc(100%_-_1.75rem))] flex-wrap items-center justify-between gap-4">
    <span>{content.name}</span>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <span>{content.footer.note}</span>
      {
        content.footer.links.map((link) => (
          <a class="font-bold text-teal-deep underline-offset-4 hover:underline" href={link.href} target="_blank" rel="noreferrer">
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
