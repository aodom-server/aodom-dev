---
import type { ResumeContent } from "../data/resume";

interface Props {
  hero: ResumeContent["hero"];
}

const { hero } = Astro.props;

function buttonClass(variant?: string) {
  if (variant === "primary") return "button button-primary";
  if (variant === "accent") return "button button-accent";
  return "button";
}

function isExternal(href?: string) {
  return href?.startsWith("http");
}
---

<section class="hero" id="top">
  <div class="hero-inner">
    <div class="hero-copy reveal">
      <p class="eyebrow">{hero.eyebrow}</p>
      <h1>{hero.title}</h1>
      <p class="lead">{hero.lead}</p>
      <div class="hero-contact" aria-label="Resume contact details">
        {
          hero.contact.map((item) =>
            item.href ? (
              <a
                class="hero-contact-item"
                href={item.href}
                target={isExternal(item.href) ? "_blank" : undefined}
                rel={isExternal(item.href) ? "noreferrer" : undefined}
              >
                <span>{item.label}</span>
                <strong>{item.text}</strong>
              </a>
            ) : (
              <span class="hero-contact-item">
                <span>{item.label}</span>
                <strong>{item.text}</strong>
              </span>
            )
          )
        }
      </div>
      <div class="hero-actions" aria-label="Primary actions">
        {
          hero.actions.map((action) => (
            <a
              class={buttonClass(action.variant)}
              href={action.href}
              target={isExternal(action.href) ? "_blank" : undefined}
              rel={isExternal(action.href) ? "noreferrer" : undefined}
              {...(action.download ? { download: true } : {})}
            >
              {action.label}
            </a>
          ))
        }
      </div>
      <div class="hero-proof" aria-label="Highlights">
        {
          hero.proof.map((item) => (
            <div class="proof-tile">
              <span class="proof-kicker">{item.label}</span>
              <strong>{item.text}</strong>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
