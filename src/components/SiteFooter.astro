---
import type { ResumeContent } from "../data/resume";

interface Props {
  content: ResumeContent;
}

const { content } = Astro.props;
---

<footer class="bg-paper py-8 text-sm text-muted">
  <div class="mx-auto flex w-[min(1160px,calc(100%_-_1.75rem))] flex-wrap justify-between gap-4">
    <span>{content.name}</span>
    <span>{content.footer.note}</span>
  </div>
</footer>
