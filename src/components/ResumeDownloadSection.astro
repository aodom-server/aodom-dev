---
import type { ResumeContent } from "../data/resume";

interface Props {
  content: ResumeContent;
}

const { content } = Astro.props;
---

<section class="bg-paper py-16 sm:py-24" id="resume">
  <div class="mx-auto w-[min(1160px,calc(100%_-_1.75rem))]">
    <div class="reveal grid gap-6 rounded-lg border border-black/10 bg-[linear-gradient(135deg,rgba(15,118,110,0.09),rgba(238,108,87,0.08))] p-6 shadow-xl shadow-black/5 opacity-0 translate-y-5 transition-all duration-700 ease-out data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100 md:grid-cols-[1fr_auto] md:items-center md:p-8">
      <div>
        <p class="mb-3 text-sm font-black uppercase tracking-[0.08em] text-teal-deep">{content.resume.label}</p>
        <h2 class="mb-3 text-3xl font-black leading-tight sm:text-4xl">{content.resume.title}</h2>
        <p class="max-w-3xl leading-7 text-muted">{content.resume.text}</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row md:flex-col lg:flex-row">
        <button class="inline-flex min-h-12 items-center justify-center rounded-lg border border-ink bg-ink px-5 font-black text-white transition hover:-translate-y-0.5" type="button" data-print>Print web resume</button>
        <a class="inline-flex min-h-12 items-center justify-center rounded-lg border border-black/15 bg-white px-5 font-black no-underline transition hover:-translate-y-0.5" href="#contact">Contact note</a>
      </div>
    </div>
  </div>
</section>
