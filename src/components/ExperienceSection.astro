---
import SectionIntro from "./SectionIntro.astro";
import type { ResumeContent } from "../data/resume";

interface Props {
  experience: ResumeContent["experience"];
}

const { experience } = Astro.props;
---

<section class="bg-paper py-16 sm:py-24" id="experience">
  <div class="mx-auto grid w-[min(1160px,calc(100%_-_1.75rem))] gap-10 lg:grid-cols-[minmax(260px,0.38fr)_1fr]">
    <SectionIntro section={experience} />
    <div class="relative grid gap-4 before:absolute before:left-4 before:top-4 before:hidden before:h-[calc(100%_-_2rem)] before:w-px before:bg-teal/25 sm:before:block">
      {
        experience.items.map((item) => (
          <article class="reveal relative grid gap-4 rounded-lg border border-black/10 bg-white/85 p-5 shadow-xl shadow-black/5 backdrop-blur sm:ml-10 sm:grid-cols-[11rem_1fr] opacity-0 translate-y-5 transition-all duration-700 ease-out data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100">
            <span class="absolute -left-[2.68rem] top-6 hidden size-3 rounded-full bg-teal ring-4 ring-paper sm:block" aria-hidden="true"></span>
            <div class="text-sm font-black uppercase tracking-[0.08em] text-teal-deep">{item.meta}</div>
            <div>
              <h3 class="mb-2 text-xl font-black leading-tight">{item.title}</h3>
              <p class="leading-7 text-muted">{item.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
