---
import type { ResumeContent } from "../data/resume";

interface Props {
  content: ResumeContent;
}

const { content } = Astro.props;
---

<section class="bg-ink py-16 text-white sm:py-24" id="contact">
  <div class="mx-auto grid w-[min(1160px,calc(100%_-_1.75rem))] gap-8 lg:grid-cols-[0.7fr_1fr] lg:items-start">
    <div class="reveal opacity-0 translate-y-5 transition-all duration-700 ease-out data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100">
      <p class="mb-3 text-sm font-black uppercase tracking-[0.08em] text-teal">{content.contact.label}</p>
      <h2 class="mb-4 text-3xl font-black leading-tight sm:text-5xl">{content.contact.title}</h2>
      <p class="max-w-xl leading-8 text-white/75">{content.contact.text}</p>
    </div>
    <div class="reveal max-w-2xl border-l-4 border-teal pl-5 opacity-0 translate-y-5 transition-all duration-700 ease-out data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100">
      <p class="leading-8 text-white/75">{content.contact.note}</p>
    </div>
  </div>
</section>
