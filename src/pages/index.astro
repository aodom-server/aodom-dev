---
import ContactSection from "../components/ContactSection.astro";
import EducationSection from "../components/EducationSection.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
import HeroSection from "../components/HeroSection.astro";
import ProfileSection from "../components/ProfileSection.astro";
import ResumeDownloadSection from "../components/ResumeDownloadSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SkillsSection from "../components/SkillsSection.astro";
import WorkSection from "../components/WorkSection.astro";
import { resumeContent } from "../data/resume";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Andrew Odom | QR Resume";
const pageDescription = "Scan-friendly resume for Andrew Odom, an Air Force BESPIN software developer working through Computer Science with a planned Cybersecurity master's path.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <a
    class="absolute left-4 top-4 z-50 rounded-md bg-ink px-4 py-2 text-sm font-bold text-white transition-transform duration-200 -translate-y-24 focus:translate-y-0"
    href="#main"
  >
    Skip to content
  </a>

  <SiteHeader content={resumeContent} />

  <main id="main">
    <HeroSection hero={resumeContent.hero} />
    <ProfileSection profile={resumeContent.profile} />
    <ExperienceSection experience={resumeContent.experience} />
    <EducationSection education={resumeContent.education} />
    <SkillsSection skills={resumeContent.skills} />
    <WorkSection work={resumeContent.work} />
    <ResumeDownloadSection content={resumeContent} />
    <ContactSection content={resumeContent} />
  </main>

  <SiteFooter content={resumeContent} />

  <noscript>
    <section class="mx-auto my-10 w-[min(760px,calc(100%-2.5rem))] rounded-lg border border-black/10 bg-white p-6">
      <h1>{resumeContent.name}</h1>
      <p>
        This resume site uses a small amount of JavaScript for animation and convenience actions.
        The public PDF is temporarily removed while contact details are placeholder-only.
      </p>
    </section>
  </noscript>
</BaseLayout>
