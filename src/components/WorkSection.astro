---
import SectionIntro from "./SectionIntro.astro";
import type { ResumeContent } from "../data/resume";

interface Props {
  work: ResumeContent["work"];
}

const { work } = Astro.props;
---

<section class="bg-white py-16 sm:py-24" id="work">
  <div class="mx-auto grid w-[min(1160px,calc(100%_-_1.75rem))] gap-8">
    <SectionIntro section={work} />
    <div class="reveal max-w-3xl border-l-4 border-teal pl-5 opacity-0 translate-y-5 transition-all duration-700 ease-out data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100">
      <h3 class="mb-3 text-2xl font-black leading-tight text-ink">{work.note.title}</h3>
      <p class="leading-7 text-muted">{work.note.text}</p>
      <div class="mt-5 flex flex-wrap gap-2" aria-label="Portfolio focus areas">
        {work.note.tags.map((tag) => <span class="rounded-full border border-black/10 bg-panel px-3 py-1 text-xs font-bold text-slate-700">{tag}</span>)}
      </div>
    </div>
  </div>
</section>
