---
import SectionIntro from "./SectionIntro.astro";
import type { ResumeContent } from "../data/resume";

interface Props {
  profile: ResumeContent["profile"];
}

const { profile } = Astro.props;
---

<section class="bg-white py-16 sm:py-24" id="snapshot">
  <div class="mx-auto grid w-[min(1160px,calc(100%_-_1.75rem))] gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(340px,1.1fr)] lg:items-start">
    <SectionIntro section={profile} />
    <div class="grid gap-4">
      {
        profile.features.map((feature, index) => (
          <article class="reveal grid gap-4 rounded-lg border border-black/10 bg-panel p-5 shadow-xl shadow-black/5 transition duration-300 hover:-translate-y-1 hover:border-teal/30 sm:grid-cols-[3rem_1fr] opacity-0 translate-y-5 data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100">
            <span class="grid size-10 place-items-center rounded-lg bg-teal/10 text-sm font-black text-teal-deep">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3 class="mb-2 text-xl font-black leading-tight text-ink">{feature.title}</h3>
              <p class="leading-7 text-muted">{feature.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
