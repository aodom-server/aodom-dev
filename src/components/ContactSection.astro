---
import type { ResumeContent } from "../data/resume";

interface Props {
  content: ResumeContent;
}

const { content } = Astro.props;

function isExternal(href?: string) {
  return href?.startsWith("http");
}
---

<section class="section section-tint" id="contact">
  <div class="section-inner">
    <div class="contact-panel reveal">
      <div>
        <p class="section-label">{content.contact.label}</p>
        <h2>{content.contact.title}</h2>
        <p>{content.contact.text}</p>
        <div class="contact-links" aria-label="Contact links">
          {
            content.contact.methods.map((method) =>
              method.href ? (
                <a
                  href={method.href}
                  target={isExternal(method.href) ? "_blank" : undefined}
                  rel={isExternal(method.href) ? "noreferrer" : undefined}
                >
                  <span>{method.label}</span>
                  <strong>{method.value}</strong>
                </a>
              ) : (
                <span class="contact-link-static">
                  <span>{method.label}</span>
                  <strong>{method.value}</strong>
                </span>
              )
            )
          }
          <button type="button" data-copy-email={content.email}>Copy email</button>
        </div>
      </div>
      <a class="button" href={`mailto:${content.email}`}>Email Andrew</a>
    </div>
  </div>
</section>
