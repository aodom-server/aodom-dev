---
import type { ResumeContent } from "../data/resume";

interface Props {
  content: ResumeContent;
}

const { content } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-black/10 bg-paper/85 backdrop-blur-xl max-md:static" aria-label="Primary navigation">
  <div class="mx-auto flex min-h-16 w-[min(1160px,calc(100%_-_2rem))] items-center justify-between gap-4 md:min-h-[72px]">
    <a class="inline-flex items-center gap-3 text-sm font-black no-underline sm:text-base" href="#top" aria-label={`AO ${content.name} home`}>
      <img
        class="h-10 w-20 rounded-lg object-cover shadow-lg shadow-black/10 ring-1 ring-white/50 sm:h-11 sm:w-24"
        src="/assets/ao-logo.jpg"
        alt=""
        width="640"
        height="398"
        decoding="async"
        fetchpriority="high"
        aria-hidden="true"
      />
      <span>{content.name}</span>
    </a>
    <nav class="nav-links hidden items-center gap-1 lg:flex" aria-label="Sections">
      {
        content.nav.map((item) => (
          <a
            class="inline-flex min-h-10 items-center rounded-lg px-3 text-sm font-semibold text-muted transition hover:-translate-y-0.5 hover:bg-teal/10 hover:text-teal-deep aria-[current=page]:bg-teal/10 aria-[current=page]:text-teal-deep"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <a
      class="hidden min-h-10 items-center justify-center rounded-lg border border-black/15 bg-white/70 px-4 text-sm font-extrabold no-underline transition hover:-translate-y-0.5 hover:border-teal/40 hover:bg-white sm:inline-flex"
      href="#contact"
    >
      Contact
    </a>
  </div>
</header>
