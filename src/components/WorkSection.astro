---
import SectionIntro from "./SectionIntro.astro";
import type { ResumeContent } from "../data/resume";

interface Props {
  work: ResumeContent["work"];
}

const { work } = Astro.props;

function isExternal(href: string) {
  return href.startsWith("http");
}
---

<section class="bg-white py-16 sm:py-24" id="work">
  <div class="mx-auto grid w-[min(1160px,calc(100%_-_1.75rem))] gap-10">
    <SectionIntro section={work} />
    <div class="grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
      {
        work.cards.map((project, index) => (
          <a
            class={`reveal group min-h-72 overflow-hidden rounded-lg border border-black/10 bg-panel shadow-xl shadow-black/5 no-underline transition duration-300 hover:-translate-y-1 hover:border-blue-steel/30 hover:shadow-2xl opacity-0 translate-y-5 data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100 ${index === 0 ? "lg:row-span-2" : ""}`}
            href={project.href}
            target={isExternal(project.href) ? "_blank" : undefined}
            rel={isExternal(project.href) ? "noreferrer" : undefined}
          >
            <div class={`flex min-h-28 items-start justify-between gap-3 border-b border-black/10 p-5 ${index === 0 ? "bg-[linear-gradient(135deg,rgba(15,118,110,0.16),rgba(37,87,167,0.08))]" : index === 1 ? "bg-[linear-gradient(135deg,rgba(238,108,87,0.14),rgba(143,184,63,0.09))]" : "bg-[linear-gradient(135deg,rgba(37,87,167,0.14),rgba(15,118,110,0.09))]"}`}>
              <span class="text-sm font-black uppercase tracking-[0.08em] text-slate-600">{project.type}</span>
              <span class="rounded-full bg-white/85 px-3 py-1 text-xs font-black text-ink">{project.badge}</span>
            </div>
            <div class="flex min-h-44 flex-col p-5">
              <h3 class="mb-3 text-2xl font-black leading-tight text-ink">{project.title}</h3>
              <p class="mb-6 leading-7 text-muted">{project.text}</p>
              <div class="mt-auto flex flex-wrap gap-2" aria-label="Project stack">
                {project.tags.map((tag) => <span class="rounded-full border border-black/10 bg-white px-3 py-1 text-xs font-bold text-slate-700">{tag}</span>)}
              </div>
              <span class="mt-6 inline-flex font-black text-blue-steel transition group-hover:translate-x-1">{project.linkText}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
