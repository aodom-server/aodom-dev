---
import SectionIntro from "./SectionIntro.astro";
import type { ResumeContent } from "../data/resume";

interface Props {
  work: ResumeContent["work"];
}

const { work } = Astro.props;

const insightClass = "reveal flex min-h-64 flex-col rounded-lg border border-black/10 bg-panel p-5 shadow-xl shadow-black/5 opacity-0 translate-y-5 transition-all duration-700 ease-out hover:-translate-y-1 data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100";
---

<section class="bg-white py-16 sm:py-24" id="work">
  <div class="mx-auto grid w-[min(1160px,calc(100%_-_1.75rem))] gap-8">
    <SectionIntro section={work} />
    <div class="reveal max-w-3xl border-l-4 border-teal pl-5 opacity-0 translate-y-5 transition-all duration-700 ease-out data-[visible=true]:translate-y-0 data-[visible=true]:opacity-100">
      <h3 class="mb-3 text-2xl font-black leading-tight text-ink">{work.note.title}</h3>
      <p class="leading-7 text-muted">{work.note.text}</p>
      <div class="mt-5 flex flex-wrap gap-2" aria-label="Portfolio focus areas">
        {work.note.tags.map((tag) => <span class="rounded-full border border-black/10 bg-panel px-3 py-1 text-xs font-bold text-slate-700">{tag}</span>)}
      </div>
    </div>
    <div class="grid gap-4 lg:grid-cols-3">
      {
        work.insights.map((item) => (
          item.href ? (
            <a class={`${insightClass} no-underline`} href={item.href} target="_blank" rel="noopener noreferrer">
              <span class="mb-4 text-xs font-black uppercase tracking-[0.08em] text-teal-deep">{item.meta}</span>
              <h3 class="mb-3 text-xl font-black leading-tight text-ink">{item.title}</h3>
              <p class="leading-7 text-muted">{item.text}</p>
              <div class="mt-5 flex flex-wrap gap-2" aria-label={`${item.title} focus areas`}>
                {item.tags.map((tag) => <span class="rounded-full border border-black/10 bg-white px-3 py-1 text-xs font-bold text-slate-700">{tag}</span>)}
              </div>
              <span class="mt-auto pt-6 font-black text-blue-steel">{item.linkText}</span>
            </a>
          ) : (
            <article class={insightClass}>
              <span class="mb-4 text-xs font-black uppercase tracking-[0.08em] text-teal-deep">{item.meta}</span>
              <h3 class="mb-3 text-xl font-black leading-tight text-ink">{item.title}</h3>
              <p class="leading-7 text-muted">{item.text}</p>
              <div class="mt-5 flex flex-wrap gap-2" aria-label={`${item.title} focus areas`}>
                {item.tags.map((tag) => <span class="rounded-full border border-black/10 bg-white px-3 py-1 text-xs font-bold text-slate-700">{tag}</span>)}
              </div>
            </article>
          )
        ))
      }
    </div>
  </div>
</section>
